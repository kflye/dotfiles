{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "permission": {
    "bash": {
      "*": "allow",
      "sudo *": "deny",
      "doas *": "deny",
      "mv /*": "deny",
      "> /*": "deny",
      "cp -r /*": "deny",
      "rm -rf*": "deny",
      "rm -r *": "deny",
      "rmdir *": "deny",
      "chmod -R*": "deny",
      "chown -R*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "npm install*": "deny",
      "npm i *": "deny",
      "npm i": "deny",
      "npm uninstall*": "deny",
      "yarn add*": "deny",
      "yarn remove*": "deny",
      "pnpm add*": "deny",
      "pnpm remove*": "deny",
      "bun add*": "deny",
      "bun remove*": "deny",
      "brew install*": "deny",
      "brew uninstall*": "deny",
      "pip install*": "deny",
      "pip uninstall*": "deny",
      "cargo install*": "deny",
      "git *": "deny",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote -v*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git blame*": "allow",
      "git shortlog*": "allow",
      "git describe*": "allow",
      "git cat-file*": "allow",
      "git reflog*": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/repos/**": "allow"
    }
  },
  "agent": {
    "supervisor": {
      "permission": {
        "task": {
          "*": "allow"
        }
      },
      "options": {}
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1"
      },
      "models": {
        "unsloth/Qwen3.6-27B-GGUF:Q4_K_M": {
          "name": "Qwen3.6-27B Q4_K_M (local)",
          "limit": {
            "context": 65536,
            "output": 65536
          }
        }
      }
    }
    ,
    "mlx_lm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "mlx_lm.server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8001/v1"
      },
      "models": {
        "mlx-community/Qwen3.6-35B-A3B-4bit": {
          "name": "Qwen3.6-35B-A3B 4bit (mlx_lm local)",
          "limit": {
            "context": 65536,
            "output": 65536
          }
        }
      }
    }
  }
}
