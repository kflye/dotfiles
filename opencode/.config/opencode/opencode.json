{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "permission": {
    "bash": {
      "*": "allow",
      "sudo *": "deny",
      "doas *": "deny",
      "mv /*": "deny",
      "> /*": "deny",
      "cp -r /*": "deny",
      "rm -rf*": "deny",
      "rm -r *": "deny",
      "rmdir *": "deny",
      "chmod -R*": "deny",
      "chown -R*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "npm install*": "deny",
      "npm i *": "deny",
      "npm i": "deny",
      "npm uninstall*": "deny",
      "yarn add*": "deny",
      "yarn remove*": "deny",
      "pnpm add*": "deny",
      "pnpm remove*": "deny",
      "bun add*": "deny",
      "bun remove*": "deny",
      "brew install*": "deny",
      "brew uninstall*": "deny",
      "pip install*": "deny",
      "pip uninstall*": "deny",
      "cargo install*": "deny",
      "git *": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote -v*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git blame*": "allow",
      "git shortlog*": "allow",
      "git describe*": "allow",
      "git cat-file*": "allow",
      "git reflog*": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/repos/**": "allow"
    }
  },
  "agent": {
    "supervisor": {
      "permission": {
        "task": {
          "*": "allow"
        }
      },
      "options": {}
    }
  },
  "plugin": [
    "opencode-local-provider"
  ]
}
